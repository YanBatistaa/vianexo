{
  "name": "vianexo",
  "version": "0.3.0",
  "private": true,
  "description": "ViaNexo: aplicacao desktop para gestao operacional de fretamento, frota e roteiros.",
  "author": "ViaNexo",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 tsx scripts/dev-electron.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.main.json && vite build",
    "lint": "eslint . --ext .ts,.tsx",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "package": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish never",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "test:permissions": "tsx scripts/permissions-test.ts",
    "test:contracts": "tsx scripts/ipc-contract-test.ts",
    "release:changelog": "tsx scripts/generate-changelog.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "br.com.vianexo.desktop",
    "productName": "ViaNexo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "prisma-client/**/*",
      "assets/**/*",
      "package.json",
      "prisma/schema.prisma"
    ],
    "asarUnpack": [
      "prisma-client/query_engine-*.node"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma",
        "filter": [
          "schema.prisma",
          "migrations/**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/vianexo-icon.ico",
      "signAndEditExecutable": false,
      "signDlls": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YanBatistaa",
        "repo": "vianexo"
      }
    ]
  }
}
